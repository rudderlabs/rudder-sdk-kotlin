<?xml version="1.0" encoding="utf-8"?>
<!--
  Driver-side manifest. AGP merges this into the synthesized test manifest under
  testApplicationId = com.rudderstack.testapp.driver.

  ## Why this is no longer empty (Step 6b)

  When targetPackage = driver (set via the build-script rewrite in build.gradle.kts), the
  test process runs as the driver app under its own UID — not the SUT's. Two consequences:

   1. Android 11+ package visibility: cross-package ContentResolver / Intent traffic
      requires the caller to declare a <queries> entry for the target. Without it,
      `Failed to find provider info for com.rudderstack.testapp.state` from the
      ContentResolver and the SDK's TestApp.analytics state isn't readable.

   2. Driver-side OkHttpMockServer binds a loopback socket from inside the driver
      process — needs INTERNET on the driver manifest. (When targetPackage was SUT,
      the test inherited the SUT's permissions and INTERNET on the SUT manifest
      covered both sides; that no longer applies.)
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Driver needs INTERNET to bind the OkHttpMockServer loopback socket. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      Package visibility for the SUT. The provider authority is the actually-used handle
      (StateProbe), but listing the package itself is a small superset that also covers
      future Intent-based interactions (e.g. ActivityScenario, package introspection).
    -->
    <queries>
        <package android:name="com.rudderstack.testapp" />
        <provider android:authorities="com.rudderstack.testapp.state" />
    </queries>

</manifest>
