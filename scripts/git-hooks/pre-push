#!/bin/bash

# --- Global Hook Forwarding ---
GLOBAL_HOOKS_PATH=$(git config --global --get core.hooksPath 2>/dev/null)
if [ -n "$GLOBAL_HOOKS_PATH" ] && [ -x "$GLOBAL_HOOKS_PATH/pre-push" ]; then
    "$GLOBAL_HOOKS_PATH/pre-push" "$@" || exit $?
fi
# --- End Global Hook Forwarding ---

set -e  # Exit on any error

echo "🚀 Running pre-push checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

# 1. Check branch name
print_status "Validating branch name..."
LC_ALL=C
local_branch="$(git rev-parse --abbrev-ref HEAD)"
valid_branch_regex="^(feat|fix|hotfix|refactor|release|docs|chore|test|ci)\/[a-z0-9._-]+$"
message="There is something wrong with your branch name. Branch names in this project must adhere to this contract: $valid_branch_regex. Your push will be rejected. You should rename your branch to a valid name and try again."

if [[ ! $local_branch =~ $valid_branch_regex ]]
then
    print_error "$message"
    exit 1
fi
print_success "✅ Branch name validation passed"

# 2. Discover publishable modules via Gradle
print_status "Discovering publishable modules..."
MODULE_OUTPUT=$(./gradlew listModules --quiet 2>/dev/null)

ANDROID_MODULES=$(echo "$MODULE_OUTPUT" | grep "^ANDROID_MODULES=" | cut -d'=' -f2)
JVM_MODULES=$(echo "$MODULE_OUTPUT" | grep "^JVM_MODULES=" | cut -d'=' -f2)

if [ -z "$ANDROID_MODULES" ] || [ -z "$JVM_MODULES" ]; then
    print_error "Module discovery failed. Expected both Android and JVM modules."
    [ -z "$ANDROID_MODULES" ] && print_error "ANDROID_MODULES is empty"
    [ -z "$JVM_MODULES" ] && print_error "JVM_MODULES is empty"
    exit 1
fi

# Build task lists from discovered modules
LINT_TASKS=""
BUILD_TASKS=""
TEST_TASKS=""

if [ -n "$ANDROID_MODULES" ]; then
    IFS=',' read -ra A_MODS <<< "$ANDROID_MODULES"
    for mod in "${A_MODS[@]}"; do
        LINT_TASKS="$LINT_TASKS ${mod}:lintDebug"
        BUILD_TASKS="$BUILD_TASKS ${mod}:assembleDebug"
        TEST_TASKS="$TEST_TASKS ${mod}:testDebugUnitTest"
    done
    print_success "Android modules: ${ANDROID_MODULES//,/, }"
fi

if [ -n "$JVM_MODULES" ]; then
    IFS=',' read -ra J_MODS <<< "$JVM_MODULES"
    for mod in "${J_MODS[@]}"; do
        BUILD_TASKS="$BUILD_TASKS ${mod}:assemble"
        TEST_TASKS="$TEST_TASKS ${mod}:test"
    done
    print_success "JVM modules: ${JVM_MODULES//,/, }"
fi

# Trim leading spaces
LINT_TASKS=$(echo "$LINT_TASKS" | sed 's/^ //')
BUILD_TASKS=$(echo "$BUILD_TASKS" | sed 's/^ //')
TEST_TASKS=$(echo "$TEST_TASKS" | sed 's/^ //')

ALL_TASKS="$LINT_TASKS $BUILD_TASKS $TEST_TASKS"
ALL_TASKS=$(echo "$ALL_TASKS" | sed 's/^ //')

# Print checklist of checks that will run
echo ""
echo "Checks to run:"
[ -n "$LINT_TASKS" ] && echo "  - Android Lint (lintDebug)"
[ -n "$BUILD_TASKS" ] && echo "  - Build (assembleDebug / assemble)"
[ -n "$TEST_TASKS" ] && echo "  - Unit Tests (testDebugUnitTest / test)"

# 3. Run all checks in a single Gradle invocation (incremental build + build cache)
echo ""
SEPARATOR="────────────────────────────────────────"
echo "$SEPARATOR"
print_status "Running lint, build, and tests..."
print_status "./gradlew $ALL_TASKS --parallel"
echo "$SEPARATOR"
if ! ./gradlew $ALL_TASKS --parallel; then
    echo ""
    print_error "❌ Pre-push checks failed! Please fix the issues before pushing."
    exit 1
fi
echo ""
print_success "✅ Lint, build, and tests passed"

echo ""
print_success "🎉 All pre-push checks passed! Ready to push."
exit 0
